# Database
DB_URL=jdbc:postgresql://localhost:5432/secondhanduz
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT (at least 32 characters)
JWT_SECRET=your-very-long-and-secure-secret-key-at-least-256-bits
JWT_EXPIRATION_MS=86400000

# ATMOS Payment
ATMOS_BASE_URL=https://partner.atmos.uz
ATMOS_STORE_ID=your-store-id
ATMOS_CONSUMER_KEY=your-consumer-key
ATMOS_CONSUMER_SECRET=your-consumer-secret
ATMOS_WEBHOOK_SECRET=your-webhook-secret

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# File uploads
UPLOAD_PATH=./uploads
